{
  "name": "@ntrust/monorepo",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write './**/*.{mjs,ts}'",
    "ntrust": "tsx packages/ntrust/src/cli.ts",
    "release": "bumpp package.json packages/*/package.json --commit --push --tag",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck",
    "preversion": "turbo run test:ci"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "bumpp": "latest",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=v24.0.0"
  }
}
